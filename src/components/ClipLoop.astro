---
interface Props {
  src: string;
  poster?: string;
  caption?: string;
}
const { src, poster, caption } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const finalSrc = src.startsWith('http') || src.startsWith('/') ? `${base}${src}` : src;
const finalPoster = poster
  ? (poster.startsWith('http') || poster.startsWith('/') ? `${base}${poster}` : poster)
  : undefined;
---
<figure class="clip-loop">
  <video
    src={finalSrc}
    poster={finalPoster}
    muted
    loop
    playsinline
    preload="metadata"
  ></video>
  {caption && <figcaption>{caption}</figcaption>}
</figure>
