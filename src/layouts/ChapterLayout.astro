---
import '../styles/global.css';

interface Props {
  number: number;
  title: string;
  prevSlug?: string;
  nextSlug?: string;
}

const { number, title, prevSlug, nextSlug } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Murder on the Arizona Strip</title>
  <meta name="theme-color" content="#1f1d1a" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#11100e" media="(prefers-color-scheme: dark)" />
</head>
<body>
  <div class="progress" aria-hidden="true"><div class="progress-bar"></div></div>
  <header class="book-header">
    <a href={`${base}/`}>Murder on the Arizona Strip</a>
  </header>
  <main>
    <article>
      <h1 class="chapter-number">Chapter {number}</h1>
      <h1 class="chapter-title">{title}</h1>
      <slot />
    </article>
    <nav class="chapter-nav" aria-label="Chapter navigation">
      {prevSlug
        ? <a href={`${base}/chapter/${prevSlug}/`}>← Previous</a>
        : <a href={`${base}/`}>← Cover</a>}
      {nextSlug
        ? <a href={`${base}/chapter/${nextSlug}/`}>Next →</a>
        : <a href={`${base}/`}>Cover →</a>}
    </nav>
  </main>
  <script>
    import '../scripts/reading.ts';
  </script>
</body>
</html>
